  "num_layers": 1,
  "dropout": 0.0,
  "learning_rate": 0.001,
  "grad_clip": 1.0,
  "temperature": 0.9,
  "top_k": 50,
  "device": "cuda",
  "batch_size": 128,
  "epochs": 20
}
